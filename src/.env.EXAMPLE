##############################
###      BOT SETTINGS      ###
##############################
PREFIX=>
TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE


##############################
###   ADVANCED SETTINGS    ###
##############################
# Logging levels: DEBUG=10, INFO=20, WARN=30, ERROR=40, CRITICAL=50
# See: https://docs.python.org/3/library/logging.html#logging-levels
BOT_LOG_LEVEL=20
API_LOG_LEVEL=20
DB_LOG_LEVEL=20

STREAM_LOGS=True

# Database — don't change unless you know what you're doing
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
PGUSER=postgres
# POSTGRES_USER must match PGUSER — the postgres image uses this to create the superuser
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=eos
DATABASE_URL=postgres://${PGUSER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
RUN_MIGRATIONS_BEFORE_STARTUP=false

# Flask — don't change unless you know what you're doing
FLASK_APP=api.py
FLASK_RUN_HOST=api
FLASK_RUN_PORT=5000
FLASK_URL=http://${FLASK_RUN_HOST}:${FLASK_RUN_PORT}

# The guild which controls the DB and moderation
MASTER_GUILD=
