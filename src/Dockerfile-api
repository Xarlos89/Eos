FROM python:3.12-slim-bookworm

ARG FLASK_RUN_PORT=5000

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy \ 
    UV_PROJECT_ENVIRONMENT=/api/.venv

COPY --from=ghcr.io/astral-sh/uv:0.11.14 /uv /uvx /usr/local/bin/

WORKDIR /api

COPY pyproject.toml uv.lock ./
COPY src/api/pyproject.toml src/api/pyproject.toml

RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --no-install-project --no-dev --package eos-api

COPY src/api ./src/api

RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --no-dev --package eos-api

RUN useradd -r -M apiuser && chown -R apiuser:apiuser /api
USER apiuser

ENV PATH="/api/.venv/bin:$PATH"

EXPOSE ${FLASK_RUN_PORT}
CMD ["sh", "-c", "exec gunicorn -w 2 --timeout 60 --graceful-timeout 30 --access-logfile - --error-logfile - -b 0.0.0.0:${FLASK_RUN_PORT} --chdir /api/src/api  api:app"]
