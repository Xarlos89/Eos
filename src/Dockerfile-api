FROM python:3.14-slim-bookworm

ARG FLASK_RUN_PORT=5000

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

WORKDIR /api

COPY /api/requirements-api.txt /api/requirements-api.txt
RUN --mount=type=cache,target=/root/.cache/pip pip install -r /api/requirements-api.txt

COPY /api /api/

RUN useradd -r -M apiuser && chown -R apiuser:apiuser /api
USER apiuser

EXPOSE ${FLASK_RUN_PORT}
CMD ["sh", "-c", "exec gunicorn -w 2 --timeout 60 --graceful-timeout 30 --access-logfile - --error-logfile - -b 0.0.0.0:${FLASK_RUN_PORT} api:app"]
