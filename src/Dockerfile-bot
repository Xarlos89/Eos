FROM python:3.12-slim-bookworm

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy \
    UV_PROJECT_ENVIRONMENT=/bot/.venv \
    UV_NO_CACHE=1

COPY --from=ghcr.io/astral-sh/uv:0.11.14 /uv /uvx /usr/local/bin/

WORKDIR /bot

COPY pyproject.toml uv.lock ./
COPY src/bot/pyproject.toml src/bot/pyproject.toml

RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --no-install-project --no-dev --package eos-bot

COPY src/bot ./src/bot

RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --no-dev --package eos-bot

RUN useradd -r -M botuser && chown -R botuser:botuser /bot
USER botuser

CMD ["uv", "run", "--frozen", "--no-dev", "--package", "eos-bot", "python", "src/bot/main.py"]